def list_templates(fast_only=False, all_templates=False):
    """列出可用模板"""
    # Skills templates (LLM mode)
    if not fast_only:
        if not os.path.exists(SKILLS):
            print(f"错误: 未找到模板目录 {SKILLS}", file=sys.stderr)
            sys.exit(1)
        items = []
        for d in sorted(os.listdir(SKILLS)):
            smd = os.path.join(SKILLS, d, "SKILL.md")
            if not os.path.exists(smd): continue
            fm, _ = parse_skill_md(smd)
            name = fm.get("zh_name") or fm.get("en_name") or fm.get("name") or d
            desc = fm.get("description", "")
            emoji = fm.get("emoji", "📄")
            cat = fm.get("category", "")
            items.append((d, emoji, name, cat, desc))
        print(f"\n📦 LLM 模式模板 ({len(items)} 个)\n")
        print(f"{'模板ID':<30} {'类别':<12} {'名称':<24} {'说明'}")
        print("-" * 100)
        for tid, emoji, name, cat, desc in items:
            print(f"{tid:<30} {cat:<12} {emoji} {name:<22} {desc}")

    # Fast templates (deterministic)
    if fast_only or all_templates:
        fast_items = []
        if os.path.exists(FAST_DIR):
            for d in sorted(os.listdir(FAST_DIR)):
                tj = os.path.join(FAST_DIR, d, "template.json")
                if not os.path.exists(tj): continue
                with open(tj) as f:
                    meta = json.load(f)
                fast_items.append((meta.get('id',d), meta.get('name',d),
                                   meta.get('description',''), meta.get('renderer',''),
                                   meta.get('aspectHint','')))
        print(f"\n⚡ Fast 模式模板 (--fast, {len(fast_items)} 个)\n")
        print(f"{'模板ID':<35} {'Renderer':<25} {'说明'}")
        print("-" * 100)
        for tid, name, desc, renderer, aspect in fast_items:
            print(f"{tid:<35} {renderer:<25} {desc}")
        if fast_items:
            print(f"\n用法: html-render-lite --fast --template <id> --input source.md --out /tmp/out.html")

def assemble(template_id, content, format="markdown", out=None, package=None, caller=None, title=None):
    """组装上下文字符串（LLM 模式）"""
    tdir = os.path.join(SKILLS, template_id)
    smd = os.path.join(tdir, "SKILL.md")
    ex_html = os.path.join(tdir, "example.html")

    if not os.path.exists(smd):
        return f"错误: 模板 '{template_id}' 不存在 (路径: {smd})"

    fm, body = parse_skill_md(smd)
    shared = load_shared_directives()

    example_snippet = ""
    if os.path.exists(ex_html):
        with open(ex_html) as f:
            ex_text = f.read()
        lines = ex_text.split('\n')
        example_snippet = "\n".join(lines[:80])
        if len(lines) > 80:
            example_snippet += "\n  ... (以下略)"

    name = fm.get("zh_name") or fm.get("en_name") or fm.get("name") or template_id
    emoji = fm.get("emoji", "📄")

    ctx = f"""=== 模板标识 ===
ID: {template_id}
名称: {emoji} {name}
类别: {fm.get("category","")}
场景: {fm.get("scenario","")}
比例: {fm.get("aspect_hint","")}

=== 共享设计约束 ===
{shared}

=== 模板风格定义 ===
{body}

=== 视觉参考 (example.html 开头) ===
{example_snippet}

=== 用户内容 ===
{content}
"""

    if package:
        out_html = os.path.join(package, "output.html")
        src_md   = os.path.join(package, "source.md")
        meta_json = os.path.join(package, "meta.json")
        meta = {
            "template": template_id,
            "generator": "html-render-lite",
            "caller": caller or "unknown",
            "title": title or "",
            "created": datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
        }
        ctx += f"""
=== 输出指令（package 模式）===
请完成以下步骤：
1. 创建目录（如不存在）: {package}
2. 用 Write 工具将完整 HTML 写入: {out_html}
3. 用 Write 工具将以下 JSON 写入 {meta_json}:
   {json.dumps(meta, ensure_ascii=False, indent=2)}
4. 用 Write 工具将原始用户内容写入: {src_md}
5. 运行验证: html-render-lite --validate {out_html} --template {template_id}
6. 如有问题: html-render-lite --fix {out_html}
7. 报告: 各文件路径 + output.html 大小 + validate 结果
"""
    elif out:
        ctx += f"""
=== 输出指令 ===
1. 用 Write 工具将完整 HTML 写入: {out}
2. 运行验证: html-render-lite --validate {out} --template {template_id}
3. 如有问题: html-render-lite --fix {out}
4. 报告: 路径 + 文件大小 + validate 结果
"""
    else:
        ctx += "\n请严格按照以上模板风格，生成一份完整的自包含单文件 HTML。\n"

    return ctx

def main():
    parser = argparse.ArgumentParser(description="html-render-lite — 本地模板渲染器")
    parser.add_argument("--template", "-t", help="模板 ID")
    parser.add_argument("--input", "-i", help="输入文件 (默认 stdin)")
    parser.add_argument("--out", "-o", help="输出 HTML 路径")
    parser.add_argument("--package", "-p", help="输出包目录（source.md / output.html / meta.json）")
    parser.add_argument("--caller", help="调用方标识，写入 meta.json")
    parser.add_argument("--title", help="标题，写入 meta.json")
    parser.add_argument("--fast", action="store_true", help="确定性本地渲染模式（不调用 LLM）")
    parser.add_argument("--describe", action="store_true", help="输出 fast 模板的输入格式说明（source_spec.md）")
    parser.add_argument("--list", "-l", action="store_true", help="列出 LLM 模式模板")
    parser.add_argument("--list-fast", action="store_true", help="列出 fast 模式模板")
    parser.add_argument("--list-all", action="store_true", help="列出所有模板（LLM + fast）")
    parser.add_argument("--format", "-f", default="markdown", help="输入格式 (default: markdown)")
    parser.add_argument("--validate", "-v", metavar="FILE", help="验证已生成的 HTML 文件")
    parser.add_argument("--fix", "-x", metavar="FILE", help="自动修复已生成的 HTML")
    args = parser.parse_args()

    if args.list_all:
        list_templates(all_templates=True)
        return
    if args.list_fast:
        list_templates(fast_only=True)
        return
    if args.list:
        list_templates()
        return

    if not args.template:
        if args.validate:
            tid = None
            fname = os.path.basename(args.validate)
            for prefix in ["deck-","frame-","video-","card-","doc-","data-","magazine-"]:
                if fname.startswith(prefix):
                    tid = fname.replace(".html","")
                    break
            warnings = validate_html(args.validate, tid)
            if warnings:
                print(f"⚠️  发现 {len(warnings)} 个问题:\n")
                for w in warnings: print(f"  {w}")
            else:
                print("✅ 验证通过，未发现问题")
            return
        if args.fix:
            fname = os.path.basename(args.fix)
            tid = fname.replace(".html","")
            cat = get_template_category(tid)
            needs_js = template_needs_nav(tid, cat)
            with open(args.fix) as f:
                html = f.read()
            fixed = False
            if needs_js and 'keydown' not in html:
                js = PRESENTER_NAV_JS if tid == "deck-presenter-mode" else DECK_NAV_JS
                html = html.replace('</body>', f'{js}\n</body>')
                fixed = True
                print(f"  ✅ 注入键盘导航 JS ({tid} 是 {cat} 类型)")
            if needs_js and '.bar' not in html and '<div class="bar">' not in html:
                bar = '<div class="bar"><span style="width:12.5%"></span></div>'
                html = html.replace('<div class="deck">', f'<div class="deck">{bar}')
                fixed = True
                print("  ✅ 注入进度条")
            if fixed:
                with open(args.fix, 'w') as f: f.write(html)
                print(f"  ✅ {args.fix} 已修复")
            else:
                print("  ✅ 无需修复")
            return
        parser.print_help()
        print("\n使用 --list 查看 LLM 模式模板，--list-fast 查看 fast 模式模板", file=sys.stderr)
        sys.exit(1)

    # Fast mode: --describe prints source_spec.md (no content needed)
    if args.fast and args.describe:
        ft = _load_fast_template(args.template)
        if not ft:
            print(f"错误: fast 模板 '{args.template}' 不存在", file=sys.stderr)
            sys.exit(1)
        spec = ft.get("source_spec", "")
        if spec:
            print(spec)
        else:
            print(f"模板 {args.template} 没有 source_spec.md，输入格式无特殊要求（普通 Markdown 即可）。")
        return

    # Read content
    if args.input:
        with open(args.input) as f:
            content = f.read()
    else:
        if sys.stdin.isatty() and not args.fast:
            print("提示: 等待 stdin 输入... (或使用 --input 指定文件)", file=sys.stderr)
        content = sys.stdin.read()

    if not content.strip():
        print("错误: 内容为空", file=sys.stderr)
        sys.exit(1)

    # Fast mode: deterministic render
    if args.fast:
        render_fast(args.template, content,
                    out=args.out, package=args.package,
                    caller=args.caller, title=args.title)
        return

    # LLM mode: assemble context
    if args.package:
        os.makedirs(args.package, exist_ok=True)
    result = assemble(args.template, content, args.format,
                      out=args.out, package=args.package,
                      caller=args.caller, title=args.title)
    print(result)

if __name__ == "__main__":
    main()
