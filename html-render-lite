"""
html-render-lite: 读取本地模板，输出结构化上下文，当前 LLM 直接写 HTML。
--fast 模式：确定性本地渲染，不调用 LLM，直接输出完整 HTML。

用法:
  echo "Markdown content" | html-render-lite --template doc-kami-parchment
  html-render-lite --template deck-simple --input source.md --out /tmp/out.html
  html-render-lite --template card-xiaohongshu --package /tmp/pkg/
  html-render-lite --fast --template docs-page-warm-fast --input source.md --out /tmp/out.html
  html-render-lite --fast --template kami-parchment-fast --input source.md --package /tmp/pkg/
  html-render-lite --list
"""

